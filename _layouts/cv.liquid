---
layout: default
---
{% assign current_lang = page.lang | default: site.lang %}
{% assign t = site.data.i18n[current_lang] | default: site.data.i18n.en %}
{% unless site.data.resume %}
  <div class="post">
    <header class="post-header cv-header">
      <div class="cv-header-row">
        <div>
          {% if page.cv_role %}
            <p class="cv-eyebrow">{{ page.cv_role }}</p>
          {% endif %}
          <h1 class="post-title">{{ page.title }}</h1>
          {% if page.cv_intro %}
            <p class="cv-intro">{{ page.cv_intro }}</p>
          {% endif %}
          {% if page.cv_tags %}
            <div class="cv-tags">
              {% for tag in page.cv_tags %}
                <span>{{ tag }}</span>
              {% endfor %}
            </div>
          {% endif %}
          {% if page.description %}
            <p class="post-description">{{ page.description }}</p>
          {% endif %}
        </div>
        {% if page.cv_pdf %}
          <a
            href="{{ page.cv_pdf | prepend: 'assets/pdf/' | relative_url}}"
            target="_blank"
            rel="noopener noreferrer"
            class="cv-download"
          >
            <i class="fa-solid fa-file-pdf"></i>
            <span>{{ t.labels.download_pdf }}</span>
          </a>
        {% endif %}
      </div>
    </header>

    <article>
      {% if page.cv_highlights %}
        <div class="cv-highlights">
          {% for item in page.cv_highlights %}
            <div class="cv-highlight-card">
              <div class="cv-highlight-value">{{ item.value }}</div>
              <div class="cv-highlight-label">{{ item.label }}</div>
            </div>
          {% endfor %}
        </div>
      {% endif %}
      <div class="cv">
        {% for entry in site.data.cv %}
          <a class="anchor" id="{{ entry.title }}"></a>
          <section class="card mt-3 p-3 cv-section-card">
            <h3 class="card-title font-weight-medium cv-section-title">{{ entry.title }}</h3>
            <div>
              {% if entry.type == 'list' %}
                {% include cv/list.liquid %}
              {% elsif entry.type == 'map' %}
                {% include cv/map.liquid %}
              {% elsif entry.type == 'nested_list' %}
                {% include cv/nested_list.liquid %}
              {% elsif entry.type == 'time_table' %}
                {% include cv/time_table.liquid %}
              {% elsif entry.type == 'list_groups' %}
                {% include cv/list_groups.liquid %}
              {% else %}
                {{ entry.contents }}
              {% endif %}
            </div>
          </section>
        {% endfor %}
      </div>
    </article>
  </div>
{% else %}
  <div class="post">
    <header class="post-header cv-header">
      <div class="cv-header-row">
        <div>
          {% if page.cv_role %}
            <p class="cv-eyebrow">{{ page.cv_role }}</p>
          {% endif %}
          <h1 class="post-title">{{ page.title }}</h1>
          {% if page.cv_intro %}
            <p class="cv-intro">{{ page.cv_intro }}</p>
          {% endif %}
          {% if page.cv_tags %}
            <div class="cv-tags">
              {% for tag in page.cv_tags %}
                <span>{{ tag }}</span>
              {% endfor %}
            </div>
          {% endif %}
          {% if page.description %}
            <p class="post-description">{{ page.description }}</p>
          {% endif %}
        </div>
        {% if page.cv_pdf %}
          <a
            href="{{ page.cv_pdf | prepend: 'assets/pdf/' | relative_url}}"
            target="_blank"
            rel="noopener noreferrer"
            class="cv-download"
          >
            <i class="fa-solid fa-file-pdf"></i>
            <span>{{ t.labels.download_pdf }}</span>
          </a>
        {% endif %}
      </div>
    </header>

    <article>
      {% if page.cv_highlights %}
        <div class="cv-highlights">
          {% for item in page.cv_highlights %}
            <div class="cv-highlight-card">
              <div class="cv-highlight-value">{{ item.value }}</div>
              <div class="cv-highlight-label">{{ item.label }}</div>
            </div>
          {% endfor %}
        </div>
      {% endif %}
      <div class="cv">
        {% for data in site.data.resume %}
          {% if site.jsonresume and site.jsonresume.size > 0 %}
            {% unless site.jsonresume contains data[0] %}
              {% continue %}
            {% endunless %}
          {% endif %}
          {% if data[0] == 'basics' or data[0] == 'languages' %}
            {% continue %}
          {% endif %}
          {% if data[0] == 'meta' or data[1].size == 0 %} {% continue %} {% endif %}
          <a class="anchor" id="{{ data[0] }}"></a>
          <section class="card mt-3 p-3 cv-section-card">
            <h3 class="card-title font-weight-medium cv-section-title">
              {{ t.cv_sections[data[0]] | default: data[0] | capitalize }}
            </h3>
            <div>
              {% case data[0] %}
                {% when 'basics' %}
                  {% include resume/basics.liquid %}
                {% when 'education' %}
                  {% include resume/education.liquid %}
                {% when 'work' %}
                  {% include resume/work.liquid %}
                {% when 'volunteer' %}
                  {% include resume/volunteer.liquid %}
                {% when 'projects' %}
                  {% include resume/projects.liquid %}
                {% when 'awards' %}
                  {% include resume/awards.liquid %}
                {% when 'skills' %}
                  {% include resume/skills.liquid %}
                {% when 'publications' %}
                  {% include resume/publications.liquid %}
                {% when 'languages' %}
                  {% include resume/languages.liquid %}
                {% when 'interests' %}
                  {% include resume/interests.liquid %}
                {% when 'certificates' %}
                  {% include resume/certificates.liquid %}
                {% when 'references' %}
                  {% include resume/references.liquid %}
                {% else %}

              {% endcase %}
            </div>
          </section>
        {% endfor %}
      </div>
    </article>
  </div>
{% endunless %}
